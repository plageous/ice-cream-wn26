<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thank You</title>
</head>
<body>
    <h1>Thank you for your order, <%= order.name %>!</h1>
    <h2>Order Details</h2>
    <p>Name: <%= order.name %></p>
    <p>Email: <%= order.email %></p>
    <p>Cone Type: <%= order.method %></p>
    <p>Flavor: <%= order.flavor %></p>
    <p>Toppings: 
        <%= Array.isArray(order.toppings) ?
            order.toppings.join(', ') :
            "No toppings" %>
    </p>
    <p>Comment: <%= order.comments %></p>
    <a href="/">Order another?</a>
</body>
</html>